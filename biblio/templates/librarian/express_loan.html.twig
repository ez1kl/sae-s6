{% extends 'librarian/layout.html.twig' %}

{% block title %}Nouveau Prêt — Guichet{% endblock %}

{% block body %}
    <div class="section-header">
        <h1><i class="fas fa-plus-circle me-2" style="color: var(--v-gold);"></i>Nouveau prêt</h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card p-4">
                {% if reservationWarning is defined and reservationWarning %}
                    <div class="alert alert-warning mb-4" role="alert">
                        <div class="fw-semibold">Confirmation requise</div>
                        <div class="small mt-1">{{ reservationWarning }}</div>
                        <div class="small mt-1">Confirmer le prêt forcé malgré la réservation.</div>
                    </div>
                {% endif %}
                <form method="post" action="{{ path('librarian_express_loan') }}">
                    <div class="mb-4">
                        <label for="book-search-input" class="form-label small fw-semibold" style="color: var(--v-muted); text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Lora', serif;">
                            Livre à emprunter
                        </label>
                        <div class="position-relative">
                            <input
                                type="text"
                                id="book-search-input"
                                class="form-control form-select-vintage"
                                placeholder="Tapez le titre d'un livre..."
                                autocomplete="off"
                                required>
                            <input type="hidden" id="book_id" name="book_id">
                            {% if reservationWarning is defined and reservationWarning %}
                                <input type="hidden" name="force" value="1">
                            {% endif %}
                            <div id="book-search-dropdown" style="display:none; position:absolute; z-index:200; background:#fff; border:1px solid var(--v-border, #ccc); border-top:none; width:100%; max-height:220px; overflow-y:auto; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="member_id" class="form-label small fw-semibold" style="color: var(--v-muted); text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Lora', serif;">
                            Membre bénéficiaire
                        </label>
                        <select id="member_id" name="member_id" class="form-select form-select-vintage" required>
                            <option value="">— Sélectionner un membre —</option>
                            {% for member in members %}
                                <option value="{{ member.id }}" {% if pendingMemberId is defined and pendingMemberId == member.id %}selected{% endif %}>
                                    {{ member.firstName }} {{ member.lastName }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <hr style="border-color: var(--v-border);">

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="{{ path('librarian_dashboard') }}" class="btn-vintage-back text-decoration-none">
                            <i class="fas fa-arrow-left me-1"></i>Retour
                        </a>
                        <button type="submit" class="btn btn-vintage-primary px-4">
                            <i class="fas fa-check me-2"></i>{% if reservationWarning is defined and reservationWarning %}Confirmer le prêt{% else %}Valider le prêt{% endif %}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
    (function () {
        const input = document.getElementById('book-search-input');
        const hidden = document.getElementById('book_id');
        const dropdown = document.getElementById('book-search-dropdown');
        let debounceTimer;

        function renderDropdown(items) {
            dropdown.innerHTML = '';
            if (items.length === 0) {
                dropdown.style.display = 'none';
                return;
            }
            items.forEach(function (book) {
                const label = book.title + (book.author ? ' — ' + book.author.lastName : '');
                const item = document.createElement('div');
                item.style.cssText = 'padding:10px 14px; cursor:pointer; font-size:0.9rem; border-bottom:1px solid #f0ebe0;';
                item.textContent = label;
                item.addEventListener('mousedown', function (e) {
                    e.preventDefault();
                    input.value = label;
                    hidden.value = book.id;
                    dropdown.style.display = 'none';
                });
                item.addEventListener('mouseover', function () { item.style.background = '#f5f0e8'; });
                item.addEventListener('mouseout', function () { item.style.background = 'transparent'; });
                dropdown.appendChild(item);
            });
            dropdown.style.display = 'block';
        }

        function fetchBooks(q) {
            const url = q.length > 0
                ? '/api/books/search?title=' + encodeURIComponent(q) + '&limit=50'
                : '/api/books?limit=50';
            fetch(url)
                .then(function (r) { return r.json(); })
                .then(function (data) { renderDropdown(data.data || []); })
                .catch(function () { dropdown.style.display = 'none'; });
        }

        input.addEventListener('input', function () {
            hidden.value = '';
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(function () { fetchBooks(input.value.trim()); }, 200);
        });

        input.addEventListener('focus', function () {
            fetchBooks(input.value.trim());
        });

        input.addEventListener('blur', function () {
            setTimeout(function () { dropdown.style.display = 'none'; }, 200);
        });

        {% if pendingBook is defined and pendingBook %}
        // Pré-remplissage lors d'une demande de confirmation
        input.value = {{ (pendingBook.title ~ (pendingBook.author ? ' — ' ~ pendingBook.author.lastName : ''))|json_encode|raw }};
        hidden.value = {{ pendingBook.id|json_encode|raw }};
        {% endif %}
    })();
    </script>
{% endblock %}
