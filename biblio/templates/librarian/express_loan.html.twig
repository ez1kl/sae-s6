{% extends 'librarian/layout.html.twig' %}

{% block title %}Nouveau Prêt — Guichet{% endblock %}

{% block body %}
    <div class="section-header">
        <h1><i class="fas fa-plus-circle me-2" style="color: var(--v-gold);"></i>Nouveau prêt</h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card p-4">
                <form method="post" action="{{ path('librarian_express_loan') }}">
                    <div class="mb-4">
                        <label for="book_id" class="form-label small fw-semibold" style="color: var(--v-muted); text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Lora', serif;">
                            Livre à emprunter
                        </label>
                        <select id="book_id" name="book_id" class="form-select form-select-vintage" required>
                            <option value="">— Sélectionner un livre —</option>
                            {% for book in books %}
                                <option value="{{ book.id }}">
                                    {{ book.title }}{% if book.author %} — {{ book.author.lastName }}{% endif %}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="member_id" class="form-label small fw-semibold" style="color: var(--v-muted); text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Lora', serif;">
                            Membre bénéficiaire
                        </label>
                        <select id="member_id" name="member_id" class="form-select form-select-vintage" required>
                            <option value="">— Sélectionner un membre —</option>
                            {% for member in members %}
                                <option value="{{ member.id }}">{{ member.firstName }} {{ member.lastName }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <hr style="border-color: var(--v-border);">

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="{{ path('librarian_dashboard') }}" class="btn-vintage-back text-decoration-none">
                            <i class="fas fa-arrow-left me-1"></i>Retour
                        </a>
                        <button type="submit" class="btn btn-vintage-primary px-4">
                            <i class="fas fa-check me-2"></i>Valider le prêt
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
