{% extends 'librarian/layout.html.twig' %}

{% block title %}Nouveau Prêt - Guichet Rapide{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3"><i class="fas fa-plus-circle text-primary"></i> Nouveau Prêt (Express)</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm p-4">
                <form method="post" action="{{ path('librarian_express_loan') }}">
                    <div class="mb-4">
                        <label for="book_id" class="form-label fw-bold">Livre à emprunter :</label>
                        <select id="book_id" name="book_id" class="form-select" required>
                            <option value="">-- Sélectionner un livre --</option>
                            {% for book in books %}
                                <option value="{{ book.id }}">{{ book.title }} {% if book.author %}({{ book.author.lastName }}){% endif %}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="member_id" class="form-label fw-bold">Membre bénéficiaire :</label>
                        <select id="member_id" name="member_id" class="form-select" required>
                            <option value="">-- Sélectionner un membre --</option>
                            {% for member in members %}
                                <option value="{{ member.id }}">{{ member.firstName }} {{ member.lastName }} (ID: {{ member.id }})</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="d-flex justify-content-between mt-5 align-items-center">
                        <a href="{{ path('librarian_dashboard') }}" class="text-secondary text-decoration-none"><i class="fas fa-arrow-left"></i> Retour au guichet</a>
                        <button type="submit" class="btn btn-primary btn-lg px-4 shadow-sm"><i class="fas fa-check"></i> Valider le prêt</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}