{% extends 'librarian/layout.html.twig' %}

{% block title %}Guichet — Prêts & Retours{% endblock %}

{% block body %}
    <div class="section-header d-flex align-items-baseline justify-content-between">
        <h1>
            {% if app.request.query.get('q') %}
                Résultats
                <small class="fw-normal fs-6 ms-2 text-muted">
                    « {{ app.request.query.get('q') }} »
                    {% if app.request.query.get('type') == 'author' %}· auteur
                    {% elseif app.request.query.get('type') == 'member' %}· membre
                    {% else %}· titre{% endif %}
                </small>
            {% else %}
                Emprunts en cours
            {% endif %}
        </h1>
        {% if overdueLoans|length > 0 %}
            <span class="badge badge-overdue px-3 py-2">
                <i class="fas fa-exclamation-triangle me-1"></i>{{ overdueLoans|length }} retard(s)
            </span>
        {% endif %}
    </div>

    {# Stats #}
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card card-stat p-3">
                <div class="stat-value">{{ activeLoans|length }}</div>
                <div class="stat-label mt-1">Prêts actifs</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card card-stat p-3" style="border-left-color: #9B3B3B;">
                <div class="stat-value" style="color:#9B3B3B;">{{ overdueLoans|length }}</div>
                <div class="stat-label mt-1">En retard</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card card-stat p-3" style="border-left-color: #5B7A5E;">
                <div class="stat-value" style="color:#5B7A5E;">{{ availableBooks }}</div>
                <div class="stat-label mt-1">Livres disponibles</div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card card-stat p-3">
                <div class="stat-value">{{ totalBooks }}</div>
                <div class="stat-label mt-1">Livres (total)</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card card-stat p-3">
                <div class="stat-value">{{ totalMembers }}</div>
                <div class="stat-label mt-1">Adhérents (total)</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card card-stat p-3">
                <div class="stat-value">{{ totalAuthors }}</div>
                <div class="stat-label mt-1">Auteurs (total)</div>
            </div>
        </div>
    </div>

    {# Table #}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Livre</th>
                        <th>Membre</th>
                        <th>Prêté le</th>
                        <th>Retour prévu</th>
                        <th class="text-end pe-4">Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for loan in activeLoans %}
                        {% set isOverdue = loan.dueDate < date() %}
                        <tr>
                            <td class="ps-4">
                                <span class="fw-semibold" style="color: var(--v-dark);">{{ loan.book.title }}</span>
                                {% if loan.book.author %}
                                    <div class="small" style="color: var(--v-muted);">{{ loan.book.author.firstName }} {{ loan.book.author.lastName }}</div>
                                {% endif %}
                            </td>
                            <td style="color: var(--v-text);">{{ loan.member.firstName }} {{ loan.member.lastName }}</td>
                            <td class="small" style="color: var(--v-muted);">{{ loan.loanDate|date('d/m/Y') }}</td>
                            <td class="small {% if isOverdue %}text-danger fw-semibold{% else %}text-muted{% endif %}">
                                {{ loan.dueDate|date('d/m/Y') }}
                            </td>
                            <td class="text-end pe-4">
                                {% if isOverdue %}
                                    <span class="badge badge-overdue">En retard</span>
                                {% else %}
                                    <span class="badge badge-ok">Dans les temps</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5" style="color: var(--v-muted); font-family: 'Lora', serif; font-style: italic;">
                                Aucun emprunt à afficher.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
