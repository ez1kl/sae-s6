{% extends 'librarian/layout.html.twig' %}

{% block title %}Retour Rapide - Guichet Rapide{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3"><i class="fas fa-undo text-success"></i> Enregistrer un Retour (Rapide)</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm p-4">
                <form method="post" action="{{ path('librarian_express_return') }}">
                    <div class="mb-4">
                        <label for="book_id" class="form-label fw-bold">Livre à retourner :</label>
                        <select id="book_id" name="book_id" class="form-select" required>
                            <option value="">-- Sélectionner un livre à retourner --</option>
                            {% for loan in loans %}
                                <option value="{{ loan.book.id }}">
                                    {{ loan.book.title }} (Prêté à: {{ loan.member.firstName }} {{ loan.member.lastName }})
                                </option>
                            {% endfor %}
                        </select>
                        <div class="form-text text-info mt-2">
                            <i class="fas fa-info-circle"></i> Cette action clôturera automatiquement le prêt actif correspondant.
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-5 align-items-center">
                        <a href="{{ path('librarian_dashboard') }}" class="text-secondary text-decoration-none"><i class="fas fa-arrow-left"></i> Retour au guichet</a>
                        <button type="submit" class="btn btn-success btn-lg px-4 shadow-sm"><i class="fas fa-check"></i> Valider le retour</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}