{% extends 'librarian/layout.html.twig' %}

{% block title %}Enregistrer un retour — Guichet{% endblock %}

{% block body %}
    <div class="section-header">
        <h1><i class="fas fa-undo me-2" style="color: var(--v-gold);"></i>Enregistrer un retour</h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card p-4">
                <form method="post" action="{{ path('librarian_express_return') }}">
                    <div class="mb-4">
                        <label for="book-search-input" class="form-label small fw-semibold" style="color: var(--v-muted); text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Lora', serif;">
                            Livre à retourner
                        </label>
                        <div class="position-relative">
                            <input
                                type="text"
                                id="book-search-input"
                                class="form-control form-select-vintage"
                                placeholder="Tapez le titre d'un livre emprunté..."
                                autocomplete="off"
                                required>
                            <input type="hidden" id="book_id" name="book_id">
                            <div id="book-search-dropdown" style="display:none; position:absolute; z-index:200; background:#fff; border:1px solid var(--v-border, #ccc); border-top:none; width:100%; max-height:220px; overflow-y:auto; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
                            </div>
                        </div>
                        <div class="mt-2 small" style="color: var(--v-muted); font-style: italic;">
                            Le prêt actif correspondant sera automatiquement clôturé.
                        </div>
                    </div>

                    <hr style="border-color: var(--v-border);">

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="{{ path('librarian_dashboard') }}" class="btn-vintage-back text-decoration-none">
                            <i class="fas fa-arrow-left me-1"></i>Retour
                        </a>
                        <button type="submit" class="btn btn-vintage-success px-4">
                            <i class="fas fa-check me-2"></i>Valider le retour
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
    (function () {
        const form = document.querySelector('form');
        const input = document.getElementById('book-search-input');
        const hidden = document.getElementById('book_id');
        const dropdown = document.getElementById('book-search-dropdown');
        let debounceTimer;

        function clearSuggestions() {
            dropdown.innerHTML = '';
            dropdown.style.display = 'none';
        }

        function buildLabel(item) {
            return item.memberName ? item.title + ' - ' + item.memberName : item.title;
        }

        function renderDropdown(items) {
            dropdown.innerHTML = '';

            if (items.length === 0) {
                const empty = document.createElement('div');
                empty.style.cssText = 'padding:10px 14px; color:#999; font-size:0.9rem;';
                empty.textContent = 'Aucun livre trouvé.';
                dropdown.appendChild(empty);
                dropdown.style.display = 'block';
                return;
            }

            items.forEach(function (itemData) {
                const item = document.createElement('div');
                const disabled = !itemData.borrowed;
                const baseStyle = 'padding:10px 14px; font-size:0.9rem; border-bottom:1px solid #f0ebe0;';

                item.style.cssText = disabled
                    ? baseStyle + 'color:#8a8a8a; background:#faf7f1; cursor:not-allowed;'
                    : baseStyle + 'cursor:pointer;';

                const label = buildLabel(itemData);

                if (disabled) {
                    const strike = document.createElement('span');
                    strike.style.textDecoration = 'line-through';
                    strike.textContent = label;
                    item.appendChild(strike);

                    const reason = document.createElement('span');
                    reason.style.marginLeft = '8px';
                    reason.textContent = itemData.reason || 'non emprunté';
                    item.appendChild(reason);
                } else {
                    item.textContent = label;

                    item.addEventListener('mousedown', function (e) {
                        e.preventDefault();
                        input.value = label;
                        hidden.value = String(itemData.id);
                        input.setCustomValidity('');
                        dropdown.style.display = 'none';
                    });

                    item.addEventListener('mouseover', function () {
                        item.style.background = '#f5f0e8';
                    });

                    item.addEventListener('mouseout', function () {
                        item.style.background = 'transparent';
                    });
                }

                dropdown.appendChild(item);
            });

            dropdown.style.display = 'block';
        }

        function fetchSuggestions(query) {
            const url = '{{ path('librarian_return_book_suggest') }}?q=' + encodeURIComponent(query);

            fetch(url, {
                headers: {
                    'Accept': 'application/json'
                }
            })
                .then(function (response) {
                    if (!response.ok) {
                        throw new Error('HTTP ' + response.status);
                    }

                    return response.json();
                })
                .then(function (payload) {
                    renderDropdown(payload.suggestions || []);
                })
                .catch(function () {
                    clearSuggestions();
                });
        }

        input.addEventListener('input', function () {
            hidden.value = '';
            input.setCustomValidity('Veuillez sélectionner un livre dans la liste.');
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(function () {
                fetchSuggestions(input.value.trim());
            }, 200);
        });

        input.addEventListener('focus', function () {
            fetchSuggestions(input.value.trim());
        });

        input.addEventListener('blur', function () {
            setTimeout(function () { dropdown.style.display = 'none'; }, 200);
        });

        form.addEventListener('submit', function (event) {
            if (!hidden.value) {
                input.setCustomValidity('Veuillez sélectionner un livre dans la liste.');
                input.reportValidity();
                event.preventDefault();
            }
        });
    })();
    </script>
{% endblock %}
