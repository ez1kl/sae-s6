{% extends 'librarian/layout.html.twig' %}

{% block title %}Enregistrer un retour — Guichet{% endblock %}

{% block body %}
    <div class="section-header">
        <h1><i class="fas fa-undo me-2" style="color: var(--v-gold);"></i>Enregistrer un retour</h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card p-4">
                <form method="post" action="{{ path('librarian_express_return') }}">
                    <div class="mb-4">
                        <label for="book-search-input" class="form-label small fw-semibold" style="color: var(--v-muted); text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Lora', serif;">
                            Livre à retourner
                        </label>
                        <div class="position-relative">
                            <input
                                type="text"
                                id="book-search-input"
                                class="form-control form-select-vintage"
                                placeholder="Tapez le titre d'un livre emprunté..."
                                autocomplete="off"
                                required>
                            <input type="hidden" id="book_id" name="book_id">
                            <div id="book-search-dropdown" style="display:none; position:absolute; z-index:200; background:#fff; border:1px solid var(--v-border, #ccc); border-top:none; width:100%; max-height:220px; overflow-y:auto; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
                            </div>
                        </div>
                        <div class="mt-2 small" style="color: var(--v-muted); font-style: italic;">
                            Le prêt actif correspondant sera automatiquement clôturé.
                        </div>
                    </div>

                    <hr style="border-color: var(--v-border);">

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="{{ path('librarian_dashboard') }}" class="btn-vintage-back text-decoration-none">
                            <i class="fas fa-arrow-left me-1"></i>Retour
                        </a>
                        <button type="submit" class="btn btn-vintage-success px-4">
                            <i class="fas fa-check me-2"></i>Valider le retour
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
    (function () {
        {# Données des emprunts actifs passées côté serveur pour la recherche client #}
        const activeLoans = [
            {% for loan in loans %}
            {
                bookId: {{ loan.book.id }},
                bookTitle: {{ loan.book.title|json_encode }},
                memberName: {{ (loan.member.firstName ~ ' ' ~ loan.member.lastName)|json_encode }},
                overdue: {{ loan.dueDate < date() ? 'true' : 'false' }}
            },
            {% endfor %}
        ];

        const input = document.getElementById('book-search-input');
        const hidden = document.getElementById('book_id');
        const dropdown = document.getElementById('book-search-dropdown');

        function renderDropdown(items) {
            dropdown.innerHTML = '';
            if (items.length === 0) {
                const empty = document.createElement('div');
                empty.style.cssText = 'padding:10px 14px; color:#999; font-size:0.9rem;';
                empty.textContent = 'Aucun emprunt actif trouvé.';
                dropdown.appendChild(empty);
                dropdown.style.display = 'block';
                return;
            }
            items.forEach(function (loan) {
                const label = loan.bookTitle + ' · ' + loan.memberName + (loan.overdue ? ' ⚠ retard' : '');
                const item = document.createElement('div');
                item.style.cssText = 'padding:10px 14px; cursor:pointer; font-size:0.9rem; border-bottom:1px solid #f0ebe0;';
                item.textContent = label;
                item.addEventListener('mousedown', function (e) {
                    e.preventDefault();
                    input.value = loan.bookTitle;
                    hidden.value = loan.bookId;
                    dropdown.style.display = 'none';
                });
                item.addEventListener('mouseover', function () { item.style.background = '#f5f0e8'; });
                item.addEventListener('mouseout', function () { item.style.background = 'transparent'; });
                dropdown.appendChild(item);
            });
            dropdown.style.display = 'block';
        }

        function filterAndRender() {
            const q = input.value.trim().toLowerCase();
            const filtered = q.length === 0
                ? activeLoans
                : activeLoans.filter(function (l) {
                    return l.bookTitle.toLowerCase().includes(q) || l.memberName.toLowerCase().includes(q);
                });
            renderDropdown(filtered);
        }

        input.addEventListener('input', function () {
            hidden.value = '';
            filterAndRender();
        });

        input.addEventListener('focus', function () {
            filterAndRender();
        });

        input.addEventListener('blur', function () {
            setTimeout(function () { dropdown.style.display = 'none'; }, 200);
        });
    })();
    </script>
{% endblock %}
