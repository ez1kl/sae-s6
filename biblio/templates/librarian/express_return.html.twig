{% extends 'librarian/layout.html.twig' %}

{% block title %}Enregistrer un retour — Guichet{% endblock %}

{% block body %}
    <div class="section-header">
        <h1><i class="fas fa-undo me-2" style="color: var(--v-gold);"></i>Enregistrer un retour</h1>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card p-4">
                <form method="post" action="{{ path('librarian_express_return') }}">
                    <div class="mb-4">
                        <label for="book_id" class="form-label small fw-semibold" style="color: var(--v-muted); text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Lora', serif;">
                            Livre à retourner
                        </label>
                        <select id="book_id" name="book_id" class="form-select form-select-vintage" required>
                            <option value="">— Sélectionner un emprunt actif —</option>
                            {% for loan in loans %}
                                <option value="{{ loan.book.id }}">
                                    {{ loan.book.title }} · {{ loan.member.firstName }} {{ loan.member.lastName }}{% if loan.dueDate < date() %} ⚠ retard{% endif %}
                                </option>
                            {% endfor %}
                        </select>
                        <div class="mt-2 small" style="color: var(--v-muted); font-style: italic;">
                            Le prêt actif correspondant sera automatiquement clôturé.
                        </div>
                    </div>

                    <hr style="border-color: var(--v-border);">

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="{{ path('librarian_dashboard') }}" class="btn-vintage-back text-decoration-none">
                            <i class="fas fa-arrow-left me-1"></i>Retour
                        </a>
                        <button type="submit" class="btn btn-vintage-success px-4">
                            <i class="fas fa-check me-2"></i>Valider le retour
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
